65400"/></navPoint><navPoint id="sect1-idm45952856251320" playOrder="95"><navLabel><text>Uncertainty Increases an Option’s Value</text></navLabel><content src="ch09.html#idm45952856251320"/></navPoint><navPoint id="sect1-idm45952856244408" playOrder="96"><navLabel><text>Time Is Fleeting</text></navLabel><content src="ch09.html#idm45952856244408"/></navPoint><navPoint id="sect1-idm45952856236984" playOrder="97"><navLabel><text>Real Options</text></navLabel><content src="ch09.html#idm45952856236984"/></navPoint><navPoint id="sect1-idm45952856222776" playOrder="98"><navLabel><text>Arbitrage</text></navLabel><content src="ch09.html#idm45952856222776"/></navPoint><navPoint id="sect1-idm45952856219512" playOrder="99"><navLabel><text>Agile and Architecture</text></navLabel><content src="ch09.html#idm45952856219512"/></navPoint><navPoint id="sect1-idm45952856214168" playOrder="100"><navLabel><text>Evolutionary Architecture</text></navLabel><content src="ch09.html#idm45952856214168"/></navPoint><navPoint id="sect1-idm45952856205496" playOrder="101"><navLabel><text>Amplifying Metaphors</text></navLabel><content src="ch09.html#idm45952856205496"/></navPoint></navPoint><navPoint id="chapter-idm45952856200808" playOrder="102"><navLabel><text>10. Every System Is Perfect…</text></navLabel><content src="ch10.html#Systems"/><navPoint id="sect1-idm45952856190264" playOrder="103"><navLabel><text>Heater as a System</text></navLabel><content src="ch10.html#idm45952856190264"/></navPoint><navPoint id="sect1-idm45952856178488" playOrder="104"><navLabel><text>Feedback Loops</text></navLabel><content src="ch10.html#idm45952856178488"/></navPoint><navPoint id="sect1-idm45952856171640" playOrder="105"><navLabel><text>Organized Complexity</text></navLabel><content src="ch10.html#idm45952856171640"/></navPoint><navPoint id="sect1-idm45952856164264" playOrder="106"><navLabel><text>System Effects</text></navLabel><content src="ch10.html#idm45952856164264"/></navPoint><navPoint id="sect1-idm459528