2855160136" playOrder="178"><navLabel><text>Isn’t the Code the Documentation?</text></navLabel><content src="part03.html#idm45952855160136"/></navPoint><navPoint id="sect1-idm45952855155352" playOrder="179"><navLabel><text>Choosing the Right Words</text></navLabel><content src="part03.html#idm45952855155352"/></navPoint><navPoint id="sect1-idm45952855152728" playOrder="180"><navLabel><text>Communication Tools</text></navLabel><content src="part03.html#idm45952855152728"/></navPoint></navPoint><navPoint id="chapter-idm45952855129384" playOrder="181"><navLabel><text>18. Explaining Stuff</text></navLabel><content src="ch18.html#ExplainingStuff"/><navPoint id="sect1-idm45952855121496" playOrder="182"><navLabel><text>Build a Ramp, Not a Cliff</text></navLabel><content src="ch18.html#idm45952855121496"/></navPoint><navPoint id="sect1-idm45952855112920" playOrder="183"><navLabel><text>Mind the Gap</text></navLabel><content src="ch18.html#idm45952855112920"/></navPoint><navPoint id="sect1-idm45952855101800" playOrder="184"><navLabel><text>First, Create a Language</text></navLabel><content src="ch18.html#idm45952855101800"/></navPoint><navPoint id="sect1-idm45952855094280" playOrder="185"><navLabel><text>Consistent Level of Detail</text></navLabel><content src="ch18.html#idm45952855094280"/></navPoint><navPoint id="sect1-idm45952855087176" playOrder="186"><navLabel><text>I Wanted to Have Liked To, but Didn’t Dare Be Allowed</text></navLabel><content src="ch18.html#idm45952855087176"/></navPoint></navPoint><navPoint id="chapter-idm45952855077288" playOrder="187"><navLabel><text>19. Show the Kids the Pirate Ship!</text></navLabel><content src="ch19.html#PirateShip"/><navPoint id="sect1-idm45952855066072" playOrder="188"><navLabel><text>Grab Attention</text></navLabel><content src="ch19.html#idm45952855066072"/></navPoint><navPoint id="sect1-idm45952855060888" playOrder="189"><navLabel><text>Build Excitement</text></navLabel><content src="ch19.html#idm45952855060888"/></navPoin